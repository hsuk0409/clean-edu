# =============================================================================
# 클린에듀 프로덕션 환경 변수 참고 템플릿
# =============================================================================
# 이 파일은 참고용입니다. 실제 배포 시에는 아래 중 하나에 값을 입력하세요:
#   - Vercel: Project Settings → Environment Variables
#   - 자체 서버: 서버의 실제 환경 변수 또는 비밀 관리 서비스
#
# 절대로 실제 값이 담긴 파일을 Git에 커밋하지 마세요.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Service Role Key — 절대 클라이언트에 노출 금지 (NEXT_PUBLIC_ 접두사 사용 불가)
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>


# -----------------------------------------------------------------------------
# Kakao OAuth
# -----------------------------------------------------------------------------
# Kakao Developers → 앱 → 앱 키 → REST API 키
NEXT_PUBLIC_KAKAO_REST_API_KEY=<rest-api-key>

# Kakao Developers → 앱 → 카카오 로그인 → 보안 → Client Secret
# 절대 클라이언트에 노출 금지
KAKAO_CLIENT_SECRET=<client-secret>


# -----------------------------------------------------------------------------
# 토큰 암호화 키 (AES-256-GCM)
# -----------------------------------------------------------------------------
# 32바이트 = 64자리 hex 문자열
# 생성 명령어: openssl rand -hex 32
# 주의: 운영 중 변경 시 DB에 저장된 모든 카카오 토큰 복호화 불가
TOKEN_ENCRYPTION_KEY=$(openssl rand -hex 32)


# -----------------------------------------------------------------------------
# JWT 세션 시크릿 (HS256)
# -----------------------------------------------------------------------------
# 생성 명령어: openssl rand -base64 32
# 주의: 변경 시 모든 로그인 사용자 세션 즉시 만료
SESSION_SECRET=$(openssl rand -base64 32)


# -----------------------------------------------------------------------------
# 앱 URL
# -----------------------------------------------------------------------------
# 배포된 도메인으로 변경 (후행 슬래시 없음)
# Kakao Developers Redirect URI도 동일하게 업데이트 필요:
#   → <NEXT_PUBLIC_APP_URL>/api/auth/kakao/callback
NEXT_PUBLIC_APP_URL=https://your-domain.com


# -----------------------------------------------------------------------------
# Gemini AI (Milestone 5 — 아직 미사용)
# -----------------------------------------------------------------------------
# Google AI Studio → API 키
GEMINI_API_KEY=<gemini-api-key>
