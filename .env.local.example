# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Kakao OAuth (Milestone 2)
NEXT_PUBLIC_KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret

# Token Encryption (AES-256-GCM, 32 bytes hex string)
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your_32_byte_hex_key_here

# Session JWT Secret (HS256)
# Generate: openssl rand -base64 32
SESSION_SECRET=your_session_secret_here

# Gemini AI (Milestone 5)
GEMINI_API_KEY=your_gemini_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
